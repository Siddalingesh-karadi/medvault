{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a patient or a doctor in the system.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["patient", "doctor"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "address": { "type": "string" },
        "degree": { "type": "string" },
        "isSharingEnabled": { "type": "boolean" },
        "onboardingComplete": { "type": "boolean" }
      },
      "required": ["role", "name", "email"]
    },
    "Record": {
      "title": "Medical Record",
      "description": "Metadata for an uploaded medical record (prescription or report).",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "fileURL": { "type": "string" },
        "fileName": { "type": "string" },
        "type": { "type": "string", "enum": ["prescription", "report"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "fileURL", "type", "createdAt"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "Health-related reminders for patients.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "time": { "type": "string" },
        "days": { "type": "array", "items": { "type": "string" } },
        "isDone": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "time"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profile and role-specific data."
    },
    "/records/{recordId}": {
      "schema": "Record",
      "description": "Stores patient medical records."
    },
    "/users/{userId}/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "Stores health reminders for a specific user."
    }
  }
}
